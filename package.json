{
  "name": "omnipanel",
  "version": "1.0.0",
  "type": "module",
  "description": "OmniPanel - 一体化服务器&游戏管理桌面应用",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "electron-vite build && electron-builder",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\""
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "element-plus": "^2.7.0",
    "@element-plus/icons-vue": "^2.3.0",
    "echarts": "^5.5.0",
    "vue-echarts": "^6.7.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "@xterm/addon-search": "^0.14.0",
    "monaco-editor": "^0.47.0",
    "vue-i18n": "^9.10.0",
    "ssh2": "^1.15.0",
    "better-sqlite3": "^11.0.0",
    "express": "^4.19.0",
    "cors": "^2.8.0",
    "ws": "^8.16.0",
    "simple-git": "^3.24.0",
    "dockerode": "^4.0.0",
    "compressing": "^1.10.0",
    "crypto-js": "^4.2.0",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "normalize.css": "^8.0.1",
    "highlight.js": "^11.9.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.2.0",
    "electron-vite": "^2.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "typescript": "^5.4.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "sass": "^1.72.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0",
    "@types/node": "^20.12.0",
    "@types/ssh2": "^1.15.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/ws": "^8.5.0",
    "@types/dockerode": "^3.3.0",
    "@types/crypto-js": "^4.2.0",
    "@types/uuid": "^9.0.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0"
  },
  "build": {
    "appId": "com.omnipanel.app",
    "productName": "OmniPanel",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
